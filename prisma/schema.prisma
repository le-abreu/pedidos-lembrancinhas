generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserProfileType {
  ADMIN
  CLIENT
  EXECUTOR
}

enum SupplierType {
  SUPPLIER
  EXECUTOR
  BOTH
}

enum ExpectedFileType {
  PHOTO
  DOCUMENT
  SIGNATURE
  ANY
}

enum PhaseExecutionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum PaymentMethod {
  PIX
  TRANSFER
  CREDIT_CARD
  BOLETO
}

enum PaymentInstallmentMode {
  SINGLE
  INSTALLMENT
}

enum OrderPaymentInstallmentStatus {
  OPEN
  PAID
}

enum AttachmentEntityType {
  ORDER
  ORDER_PHASE_EXECUTION
  INVOICE
}

model Company {
  id            String     @id @default(cuid())
  legalName     String
  tradeName     String
  cnpj          String     @unique
  email         String
  phone         String?
  active        Boolean    @default(true)
  customers     Customer[]
  users         User[]
  orders        Order[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Customer {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  document    String?
  email       String?
  phone       String?
  notes       String?
  active      Boolean   @default(true)
  users       User[]
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Supplier {
  id              String                @id @default(cuid())
  name            String
  document        String?
  email           String?
  phone           String?
  type            SupplierType
  notes           String?
  active          Boolean               @default(true)
  users           User[]
  orderSuppliers  OrderSupplier[]
  phaseExecutions OrderPhaseExecution[]
  workflowPhases  WorkflowPhase[]       @relation("WorkflowPhaseResponsibleSupplier")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model User {
  id               String                @id @default(cuid())
  companyId        String?
  customerId       String?
  supplierId       String?
  avatarStoredFileId String?
  company          Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  customer         Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplier         Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  avatarStoredFile StoredFile?           @relation("UserAvatar", fields: [avatarStoredFileId], references: [id], onDelete: SetNull)
  name             String
  email            String                @unique
  password         String
  active           Boolean               @default(true)
  profiles         UserProfile[]
  createdOrders    Order[]               @relation("OrderCreatedBy")
  createdPaymentPlans OrderPaymentPlan[] @relation("OrderPaymentPlanCreatedBy")
  phaseExecutions  OrderPhaseExecution[] @relation("PhaseExecutedBy")
  storedFiles      StoredFile[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model UserProfile {
  id         String          @id @default(cuid())
  userId     String
  profile    UserProfileType
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([userId, profile])
}

model OrderStatus {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  color       String
  active      Boolean         @default(true)
  workflows   WorkflowPhase[]
  orders      Order[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ShippingMethod {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  active      Boolean   @default(true)
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model OrderType {
  id          String             @id @default(cuid())
  fileStoredFileId String?
  name        String             @unique
  description String?
  active      Boolean            @default(true)
  fileStoredFile StoredFile?     @relation("OrderTypeFile", fields: [fileStoredFileId], references: [id], onDelete: SetNull)
  products    OrderTypeProduct[]
  workflow    Workflow?
  orders      Order[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model OrderTypeProduct {
  id                  String      @id @default(cuid())
  orderTypeId         String
  fileStoredFileId    String?
  orderType           OrderType   @relation(fields: [orderTypeId], references: [id], onDelete: Cascade)
  fileStoredFile      StoredFile? @relation("OrderTypeProductFile", fields: [fileStoredFileId], references: [id], onDelete: SetNull)
  name                String
  description         String?
  defaultQuantity     Int?
  defaultUnitPrice    Decimal?    @db.Decimal(10, 2)
  defaultUnitWeight   Decimal?    @db.Decimal(10, 3)
  required            Boolean     @default(false)
  active              Boolean     @default(true)
  orderItems          OrderItem[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model Workflow {
  id            String          @id @default(cuid())
  orderTypeId   String          @unique
  orderType     OrderType       @relation(fields: [orderTypeId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  active        Boolean         @default(true)
  phases        WorkflowPhase[]
  orders        Order[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model WorkflowPhase {
  id                         String                @id @default(cuid())
  workflowId                 String
  workflow                   Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  responsibleSupplierId      String?
  responsibleSupplier        Supplier?             @relation("WorkflowPhaseResponsibleSupplier", fields: [responsibleSupplierId], references: [id], onDelete: SetNull)
  name                       String
  description                String?
  order                      Int
  guidanceMessage            String?
  allowsFileUpload           Boolean               @default(false)
  expectedFileType           ExpectedFileType?
  requiresSupplier          Boolean               @default(false)
  changesOrderStatus         Boolean               @default(false)
  targetStatusId             String?
  targetStatus               OrderStatus?          @relation(fields: [targetStatusId], references: [id], onDelete: SetNull)
  allowsInvoice              Boolean               @default(false)
  requiresComment            Boolean               @default(false)
  active                     Boolean               @default(true)
  executions                 OrderPhaseExecution[]
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  @@unique([workflowId, order])
}

model Order {
  id                String                @id @default(cuid())
  companyId         String
  customerId        String
  orderTypeId       String
  workflowId        String
  currentStatusId   String
  createdById       String
  shippingMethodId  String
  requestedQuantity Int                   @default(1)
  shippingPrice     Decimal               @default(0) @db.Decimal(10, 2)
  deliveryAddress   String?
  company           Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customer          Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  orderType         OrderType             @relation(fields: [orderTypeId], references: [id], onDelete: Restrict)
  workflow          Workflow              @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  currentStatus     OrderStatus           @relation(fields: [currentStatusId], references: [id], onDelete: Restrict)
  createdBy         User                  @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  shippingMethod    ShippingMethod        @relation(fields: [shippingMethodId], references: [id], onDelete: Restrict)
  title             String
  description       String?
  requestedAt       DateTime
  expectedAt        DateTime?
  notes             String?
  active            Boolean               @default(true)
  items             OrderItem[]
  phaseExecutions   OrderPhaseExecution[]
  suppliers         OrderSupplier[]
  invoices          Invoice[]
  paymentPlans      OrderPaymentPlan[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model OrderItem {
  id                 String            @id @default(cuid())
  orderId            String
  productId          String
  order              Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            OrderTypeProduct  @relation(fields: [productId], references: [id], onDelete: Restrict)
  extraDescription   String?
  quantity           Int
  unitPrice          Decimal?          @db.Decimal(10, 2)
  unitWeight         Decimal?          @db.Decimal(10, 3)
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model OrderSupplier {
  id          String    @id @default(cuid())
  orderId     String
  supplierId  String
  role        String?
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())

  @@unique([orderId, supplierId])
}

model OrderPhaseExecution {
  id                  String               @id @default(cuid())
  orderId             String
  phaseId             String
  supplierId          String?
  executedByUserId    String?
  status              PhaseExecutionStatus @default(PENDING)
  comment             String?
  startedAt           DateTime?
  completedAt         DateTime?
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  phase               WorkflowPhase        @relation(fields: [phaseId], references: [id], onDelete: Restrict)
  supplier            Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  executedByUser      User?                @relation("PhaseExecutedBy", fields: [executedByUserId], references: [id], onDelete: SetNull)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([orderId, phaseId])
}

model Invoice {
  id           String    @id @default(cuid())
  orderId      String
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  number       String
  series       String?
  amount       Decimal   @db.Decimal(10, 2)
  issuedAt     DateTime
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model OrderPaymentPlan {
  id                String                   @id @default(cuid())
  orderId           String
  createdById       String
  method            PaymentMethod
  installmentMode   PaymentInstallmentMode   @default(SINGLE)
  installmentsCount Int                      @default(1)
  totalAmount       Decimal                  @db.Decimal(10, 2)
  notes             String?
  order             Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy         User                     @relation("OrderPaymentPlanCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  installments      OrderPaymentInstallment[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([orderId])
}

model OrderPaymentInstallment {
  id          String                        @id @default(cuid())
  planId      String
  number      Int
  dueAt       DateTime
  amount      Decimal                       @db.Decimal(10, 2)
  paidAt      DateTime?
  notes       String?
  status      OrderPaymentInstallmentStatus @default(OPEN)
  plan        OrderPaymentPlan              @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt

  @@unique([planId, number])
  @@index([dueAt])
}

model StoredFile {
  id            String           @id @default(cuid())
  bucket        String
  objectKey     String           @unique
  originalName  String
  mimeType      String?
  byteSize      Int
  checksumSha256 String?
  uploadedById  String?
  uploadedBy    User?            @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  avatarUsers   User[]           @relation("UserAvatar")
  orderTypes    OrderType[]      @relation("OrderTypeFile")
  orderTypeProducts OrderTypeProduct[] @relation("OrderTypeProductFile")
  attachments   FileAttachment[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model FileAttachment {
  id             String               @id @default(cuid())
  storedFileId   String
  entityType     AttachmentEntityType
  entityId       String
  storedFile     StoredFile           @relation(fields: [storedFileId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())

  @@index([entityType, entityId])
  @@index([storedFileId])
}
