NODE_ENV="development"
PORT="3000"
APP_URL="http://localhost:3000"
SERVER_ACTIONS_ALLOWED_ORIGINS=""

# Local Docker Compose
POSTGRES_DB="pedido_lembrancinha"
POSTGRES_USER="pedido_user"
POSTGRES_PASSWORD="pedido_password"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"

# Use the local compose database by default.
# For Neon, replace this value with the Neon connection string.
DATABASE_URL="postgresql://pedido_user:pedido_password@localhost:5432/pedido_lembrancinha?schema=public"

# Optional runtime controls
RUN_MIGRATIONS="true"
RUN_SEED="false"

# Object storage for uploads
S3_REGION="us-east-1"
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="pedido-anexos"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_FORCE_PATH_STYLE="true"
