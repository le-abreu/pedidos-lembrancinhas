COMPOSE_PROJECT_NAME=pedido-lembrancinha

NODE_ENV=development
PORT=3000
APP_PORT=3000

POSTGRES_DB=pedido_lembrancinha
POSTGRES_USER=pedido_user
POSTGRES_PASSWORD=pedido_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_LOCAL_PORT=5432

DATABASE_URL=postgresql://pedido_user:pedido_password@postgres:5432/pedido_lembrancinha?schema=public

RUN_MIGRATIONS=true
RUN_SEED=false

S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_BUCKET=pedido-anexos
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin 
MINIO_CONSOLE_PORT=9001

PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin123
